/* pages/check/check.wxss */
.container {
  padding: 10rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
  width: 100%
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: start;
  color: #2c3e50;
  margin: 30rpx 0;
}

.form-item {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 20rpx 100rpx rgba(0, 0, 0, 0.08);
  width: 120%;
  box-sizing: border - box;

}

.form-item label {
  display: block;
  font-size: 28rpx;
  color: #34495e;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.form-item input,
.form-item textarea {
  width: 80%;
  font-size: 28rpx;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.form-item input:focus,
.form-item textarea:focus {
  border-color: #6a8cfa;
}

.picker {
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.btn-box {
  margin-top: 40rpx;
  text-align: center;
}

.btn-box button {
  width: 80%;
  padding: 25rpx;
  font-size: 32rpx;
  background-color: #6a8cfa;
  color: white;
  border-radius: 50rpx;
}
