<!--pages/consult/consult.wxml-- >
    <view class="consult-container">
        <!-- 搜索框区域 -->
        <view class="search-bar">
            <input class="search-input"
                placeholder="请输入病症名称或症状搜索..."
                value="{{searchKeyword}}"
                bindinput="onInputChange"
                confirm-type="search"
                bindconfirm="onSearch" />
            <button class="search-btn" bindtap="onSearch">搜索</button>
        </view>

        <!-- 搜索结果区域 -->
        <view class="result-area" wx:if="{{searchKeyword}}">
            <view class="result-title">为您找到以下结果：</view>
            <view class="result-item" wx:for="{{resultList}}" wx:key="id">
                <view class="result-name">{{ item.name }}</view>
                <view class="result-desc">{{ item.desc }}</view>
            </view>
        </view>

        <!-- 空状态提示 -->
        <view class="empty-tip" wx:else>
            <text>请输入关键词搜索相关病症信息</text>
        </view>
    
