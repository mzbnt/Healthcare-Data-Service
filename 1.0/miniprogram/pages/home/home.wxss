/* pages/home/home.wxss */
.home-container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
}

.welcome-card {
  background-color: #6a8cfa;
  color: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}
.welcome-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.welcome-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.module-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.module-item {
  background-color: white;
  padding: 40rpx 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}
.module-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.module-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}
.module-item text {
  font-size: 28rpx;
  color: #333;
}

.tip-card {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.tip-icon {
  margin-right: 10rpx;
  font-size: 28rpx;
}
.tip-text {
  font-size: 26rpx;
  color: #666;
}
