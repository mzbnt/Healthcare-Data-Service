/* pages/login/login.wxss */
.login-container {
  padding: 80rpx 60rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.input-content {
  flex: 1;
  font-size: 30rpx;
}

.input-icon {
  font-size: 32rpx;
  margin-left: 20rpx;
}

.option-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
  font-size: 26rpx;
  color: #666;
}

.remember-me {
  display: flex;
  align-items: center;
}

.forget-password {
  color: #1976d2;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1976d2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.register-tip {
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.register-link {
  color: #1976d2;
}
