.container{
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.paper{
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  box-shadow: 0 0 20rpx rgba(0,0,0,0.1);
}
.title{
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #222;
}
.section{
  display: flex;
  margin: 20rpx 0;
  font-size: 30rpx;
}
.label{
  width: 220rpx;
  color: #666;
}
.value{
  color: #222;
  font-weight: 500;
}
.line{
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}
.bmi-box{
  text-align: center;
  padding: 20rpx;
}
.bmi-title{
  font-size: 32rpx;
  margin-bottom: 20rpx;
}
.bmi-num{
  font-size: 60rpx;
  font-weight: bold;
  color: #007aff;
}
.bmi-level{
  font-size: 28rpx;
  color: #555;
  margin-top: 10rpx;
}
.suggest-box{
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}
.suggest-title{
  font-size: 32rpx;
  font-weight: bold;
}
.suggest-content{
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-top: 10rpx;
}
.footer{
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #999;
}
.save-btn{
  margin-top: 40rpx;
  background: #007aff;
  color: #fff;
  border-radius: 10rpx;
}