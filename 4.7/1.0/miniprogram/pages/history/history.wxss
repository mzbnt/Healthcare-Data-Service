.container{
  padding: 30rpx;
  background: #f7f8fa;
  min-height: 100vh;
}
.page-title{
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}
.card{
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.time{
  font-size: 28rpx;
  color: #007aff;
  margin-bottom: 10rpx;
}
.info{
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}
.empty{
  text-align: center;
  margin-top: 100rpx;
  color: #999;
  font-size: 28rpx;
}