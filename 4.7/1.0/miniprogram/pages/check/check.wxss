page {
  background: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  padding: 20rpx;
}

/* 顶部标题卡片 */
.header-card {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 42rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 大卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 表单项组 */
.item-group {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* 输入框样式 */
.input {
  height: 88rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.input:focus {
  border-color: #409eff;
  background: #fff;
}

/* 文本域 */
.textarea {
  min-height: 120rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

.textarea:focus {
  border-color: #409eff;
  background: #fff;
}

/* picker 选择器 */
.picker-text {
  height: 88rpx;
  line-height: 88rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fafafa;
}

/* 按钮区域 */
.btn-area {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.submit-btn {
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 14rpx;
  box-shadow: 0 8rpx 20rpx rgba(64, 158, 255, 0.3);
}

.submit-btn:active {
  opacity: 0.85;
}