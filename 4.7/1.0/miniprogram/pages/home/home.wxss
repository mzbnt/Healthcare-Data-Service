/* 轮播图自适应 */
.swiper {
  width: 100%;
  height: 380rpx;
}
.banner-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 6宫格 */
.grid-container {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  box-sizing: border-box;
}
.grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}
.grid-icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 10rpx;
  display: block;
}
.grid-text {
  font-size: 26rpx;
  color: #333;
}

/* 底部按钮 */
.btn-box {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
  margin-top: 20rpx;
}
.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
}
.btn-red {
  background-color: #ff4d4f;
}
.btn-blue {
  background-color: #409eff;
}