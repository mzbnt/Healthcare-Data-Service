/* pages/register/register.wxss */
.register-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #a8c0ff 0%, #c2e9ff 50%, #e0c3fc 100%);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #222;
  margin-top: 80rpx;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 60rpx;
}

.input-item {
  width: 90%;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.input-label {
  position: absolute;
  top: -16rpx;
  left: 24rpx;
  background: #fff;
  padding: 0 12rpx;
  font-size: 26rpx;
  color: #666;
}

.input-content {
  width: 80%;
  font-size: 30rpx;
  padding: 20rpx 0;
}

.input-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #888;
}

.register-btn {
  width: 90%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(90deg, #87b6ff 0%, #c0a0f8 100%);
  color: #fff;
  font-size: 34rpx;
  border-radius: 45rpx;
  border: none;
  margin: 40rpx 0;
}

.login-tip {
  font-size: 28rpx;
  color: #666;
}

.login-link {
  color: #6a8cfa;
  font-weight: 500;
}