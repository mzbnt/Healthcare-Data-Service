/* pages/home/home.wxss */
/* 全局样式重置 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

/* 导航栏 */
.nav-bar {
  height: 88rpx;
  line-height: 88rpx;
  background-color: #2c3e50;
  color: #fff;
  text-align: center;
  font-size: 36rpx;
  font-weight: 500;
}

/* 轮播图 */
.swiper {
  width: 100%;
  height: 360rpx;
  margin-bottom: 20rpx;
}
.banner-img {
  width: 100%;
  height: 100%;
}

/* 九宫格容器 */
.grid-container {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
}
.grid-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  box-sizing: border-box;
}
.grid-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}
.grid-text {
  font-size: 30rpx;
  color: #333;
}

/* 底部按钮区 */
.btn-container {
  display: flex;
  padding: 0 20rpx;
  gap: 20rpx;
}
.btn-item {
  flex: 1;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  border-radius: 12rpx;
}
.btn-red {
  background-color: #ff6b6b;
}
.btn-blue {
  background-color: #74b9ff;
}
.btn-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
}